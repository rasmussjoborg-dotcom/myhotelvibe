# VITE_SITE_URL: Canonical production URL used for metadata, sitemap generation, and schema.
VITE_SITE_URL="https://myhotelvibe.com"

# VITE_SUPABASE_URL: Public Supabase project URL used by the read-only frontend and SEO build scripts.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"

# VITE_SUPABASE_ANON_KEY: Public anon key for the read-only frontend and SEO build scripts.
VITE_SUPABASE_ANON_KEY="YOUR_PUBLIC_ANON_KEY"

# SEO_REQUIRE_SUPABASE: When true, SEO generation fails if live Supabase data cannot be loaded.
# Keep this true in production so Vercel never ships stale local SEO pages by accident.
SEO_REQUIRE_SUPABASE="true"

# VITE_ENABLE_LOCAL_ADMIN: Optional override for the local-only admin tooling.
# Leave unset for the default behavior: enabled on localhost, disabled in production.
# Never set this in Vercel.
# VITE_ENABLE_LOCAL_ADMIN="true"

# APP_URL: Optional fallback host used by some legacy scripts and local tooling.
# APP_URL="https://myhotelvibe.com"

# GEMINI_API_KEY: Only needed for AI workflows that truly use it.
# Do not expose secrets to production unless the public frontend requires them.
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
